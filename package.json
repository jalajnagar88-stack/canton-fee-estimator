{
  "name": "canton-fee-estimator",
  "version": "0.3.0",
  "description": "Pre-submission transaction cost intelligence for Canton Network developers",
  "author": "Jalaj Nagar <jalajnagar88-stack@users.noreply.github.com>",
  "license": "Apache-2.0",
  "homepage": "https://github.com/jalajnagar88-stack/canton-fee-estimator#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/jalajnagar88-stack/canton-fee-estimator.git"
  },
  "bugs": {
    "url": "https://github.com/jalajnagar88-stack/canton-fee-estimator/issues"
  },
  "bin": {
    "canton-fee-estimator": "./dist/cli/main.js"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "build:web": "npm run build --prefix web",
    "build:all": "npm run build && npm run build:web",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint 'cli/**/*.ts' 'tests/**/*.ts' --max-warnings 0",
    "start": "ts-node cli/main.ts",
    "dev": "ts-node-dev --respawn cli/main.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "yargs": "^17.7.2",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.3",
    "ora": "^5.4.1",
    "axios": "^1.6.7"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.17",
    "@types/yargs": "^17.0.32",
    "@typescript-eslint/eslint-plugin": "^7.0.2",
    "@typescript-eslint/parser": "^7.0.2",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "keywords": [
    "canton",
    "daml",
    "fee-estimator",
    "blockchain",
    "developer-tools",
    "canton-network"
  ]
}
